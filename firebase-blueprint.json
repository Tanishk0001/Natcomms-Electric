{
  "entities": {
    "Review": {
      "title": "Review",
      "description": "A customer review and feedback entry.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the reviewer."
        },
        "rating": {
          "type": "number",
          "description": "The star rating (1-5)."
        },
        "comment": {
          "type": "string",
          "description": "The review text."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the review was submitted."
        },
        "approved": {
          "type": "boolean",
          "description": "Whether the review is approved for display."
        }
      },
      "required": ["name", "rating", "comment", "createdAt"]
    }
  },
  "firestore": {
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of customer reviews."
    }
  }
}
